"Sure! Here's an example of the back-end code for a real estate portal, using Node.js and Express.js.\n\nThis code assumes that you have already set up a database to store your real estate listings. In this example, we'll use MongoDB and Mongoose to interact with the database.\n```php\nconst express = require('express');\nconst mongoose = require('mongoose');\n\nconst app = express();\nconst port = 3000;\n\n// Connect to MongoDB\nmongoose.connect('mongodb://localhost:27017/real-estate-portal', { useNewUrlParser: true })\n  .then(() => console.log('MongoDB connected'))\n  .catch(err => console.error(err));\n\n// Define listing schema\nconst listingSchema = new mongoose.Schema({\n  title: { type: String, required: true },\n  price: { type: Number, required: true },\n  location: { type: String, required: true },\n  image: { type: String, required: true },\n  description: { type: String, required: true },\n});\n\n// Compile schema into a model\nconst Listing = mongoose.model('Listing', listingSchema);\n\n// Get all listings\napp.get('/listings', (req, res) => {\n  Listing.find()\n    .then(listings => res.json(listings))\n    .catch(err => res.status(400).json({ success: false, error: err }));\n});\n\n// Get a single listing\napp.get('/listings/:id', (req, res) => {\n  Listing.findById(req.params.id)\n    .then(listing => {\n      if (!listing) {\n        return res.status(404).json({ success: false, error: 'Listing not found' });\n      }\n\n      res.json(listing);\n    })\n    .catch(err => res.status(400).json({ success: false, error: err }));\n});\n\n// Create a new listing\napp.post('/listings', (req, res) => {\n  const newListing = new Listing({\n    title: req.body.title,\n    price: req.body.price,\n    location: req.body.location,\n    image: req.body.image,\n    description: req.body.description,\n  });\n\n  newListing.save()\n    .then(listing => res.json({ success: true, listing }))\n    .catch(err => res.status(400).json({ success: false, error: err }));\n});\n\n// Update a listing\napp.patch('/listings/:id', (req, res) => {\n  Listing.findById(req.params.id)\n    .then(listing => {\n      if (!listing) {\n        return res.status(404).json({ success: false, error: 'Listing not found' });\n      }\n\n      listing.title = req.body.title || listing.title;\n      listing.price = req.body.price || listing.price;\n      listing.location = req.body.location || listing.location;\n      listing.image = req.body.image || listing.image;\n      listing\n```"
